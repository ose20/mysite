---
import HeaderNav from "./HeaderNav.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<div class="header-shell">
		<div class="header-inner">
			<a class="site-owner" href="/" aria-label="ose20のホームページ">
				<span class="site-icon-frame" aria-hidden="true">
					<img
						class="site-icon"
						src="/apple-touch-icon.png"
						alt="やわらかい印象の狼のアイコン"
						width="60"
						height="60"
					>
				</span>
				<span class="username">ose20</span>
			</a>

			<div class="site-center">
				<a class="site-title" href="/">
					<span class="site-title-main">Light for the Afflicted</span>
					<span class="site-title-sub">苦難に光を</span>
				</a>
			</div>

			<button
				id="menuToggle"
				class="menu-toggle"
				type="button"
				aria-label="メニューを開く"
				aria-controls="headerNavRow"
				aria-expanded="false"
			>
				<span class="menu-toggle-lines" aria-hidden="true">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</button>

			<button
				id="themeToggle"
				class="theme-toggle"
				type="button"
				aria-label="ダークモードに切り替え"
				aria-pressed="false"
				data-state="light"
			>
				<span class="toggle-track" aria-hidden="true">
					<span class="toggle-icon toggle-icon-sun">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<circle cx="12" cy="12" r="3.5"></circle>
							<path d="M12 2.5v2.25M12 19.25v2.25M21.5 12h-2.25M4.75 12H2.5M18.72 5.28l-1.59 1.59M6.87 17.13l-1.59 1.59M18.72 18.72l-1.59-1.59M6.87 6.87L5.28 5.28"></path>
						</svg>
					</span>
					<span class="toggle-icon toggle-icon-moon">
						<svg viewBox="0 0 24 24" aria-hidden="true">
							<path d="M20 14.2A7.9 7.9 0 0 1 9.8 4a8.8 8.8 0 1 0 10.2 10.2Z"></path>
						</svg>
					</span>
					<span class="toggle-thumb"></span>
				</span>
			</button>
		</div>

		<div id="headerNavRow" class="header-nav-row">
			<HeaderNav currentPath={currentPath} />
		</div>
	</div>
</header>

<script is:inline>
	// PC とモバイルで同じヘッダーを使うので、先に操作対象の要素をまとめて取っておく
	const button = document.getElementById("themeToggle");
	const menuButton = document.getElementById("menuToggle");
	const navRow = document.getElementById("headerNavRow");

	// what: 最初に使うテーマを決める
	// how: 保存済みの設定があればそれを使い、なければ OS 側の設定を見る
	const getPreferredTheme = () => {
		const localStorageTheme = localStorage.getItem("theme");

		if (localStorageTheme === "light" || localStorageTheme === "dark") {
			return localStorageTheme;
		}

		if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
			return "dark";
		} else {
			return "light";
		}
	};

	// what: html に dark クラスとボタン属性を同期して、見た目と状態説明を揃える
	// how: 受け取った theme から dark/light を判定し、class / data-state / aria-label をまとめて更新する
	const applyTheme = (theme) => {
		const isDark = theme === "dark";

		document.documentElement.classList.toggle("dark", isDark);

		button?.setAttribute("data-state", theme);
		button?.setAttribute("aria-pressed", isDark.toString());
		button?.setAttribute("aria-label", isDark ? "ライトモードに切り替え" : "ダークモードに切り替え");

		localStorage.setItem("theme", theme);
	};

	applyTheme(getPreferredTheme());

	button?.addEventListener("click", () => {
		const isDark = document.documentElement.classList.contains("dark");
		applyTheme(isDark ? "light" : "dark");
	});

	// what: 画面幅に応じてメニューの開閉状態を整える
	// how: PC 幅では nav を常に表示し、モバイル幅では閉じているときだけ hidden を付ける
	const syncMenuState = () => {
		const isMobile = window.matchMedia("(max-width: 720px)").matches;
		if (!isMobile) {
			navRow?.removeAttribute("hidden");
			menuButton?.setAttribute("aria-expanded", "false");
			menuButton?.setAttribute("aria-label", "メニューを開く");
			return;
		}

		const expanded = menuButton?.getAttribute("aria-expanded") === "true";
		if (!expanded) {
			navRow?.setAttribute("hidden", "");
		}
	};

	menuButton?.addEventListener("click", () => {
		const expanded = menuButton.getAttribute("aria-expanded") === "true";
		const nextExpanded = (!expanded).toString();
		menuButton.setAttribute("aria-expanded", nextExpanded);
		menuButton.setAttribute("aria-label", expanded ? "メニューを開く" : "メニューを閉じる");
		navRow?.toggleAttribute("hidden", expanded);
	});

	syncMenuState();
	window.addEventListener("resize", syncMenuState);
</script>

<style>
  .site-header {
    /* what: ヘッダー全体の背景色と文字色を決める */
    /* how: 色は直接書かず CSS 変数を使うことで、ライト/ダーク両方に同じ構造で対応する */
    background-color: var(--header-background);
    color: var(--text-color);
  }

  .header-shell {
    /* what: ヘッダー全体の最大幅を制限する箱 */
    /* how: max-width で横に広がりすぎるのを防ぎ、margin: 0 auto で中央に置く */
    max-width: 80rem;
    margin: 0 auto;
  }

  .header-inner {
    /* what: 上段のレイアウトを 3 列に分ける */
    /* how: grid を使い、左に owner、中央に title、右に各種ボタンを置く */
    display: grid;
    /* 1fr は「余った幅を分け合う」という意味。左右が伸びて、中央の auto は中身ぶんの幅だけ使う */
    grid-template-columns: 1fr auto 1fr;
    align-items: center;

    min-height: 5.8rem;
    padding: 0.9rem 1.25rem;
  }

  .header-nav-row {
    /* what: ナビゲーション専用の下段 */
    /* how: 上段と線で区切り、padding で内側の余白を作る */
    padding: 0 1.25rem 1rem;
    border-top: 1px solid var(--header-border);
  }

  .site-owner {
    /* what: アイコンと ose20 を横並びにする */
    /* how: flex は子要素を 1 列に並べるレイアウト。align-items: center で高さの中心を揃える */
    display: flex;
    align-items: center;
    justify-self: start;
    gap: 0.85rem;

    color: inherit;
    text-decoration: none;
  }

  .site-icon-frame {
    /* what: アイコン画像を丸く切り抜く枠 */
    /* how: border-radius: 50% で円にし、overflow: hidden で外にはみ出した画像を隠す */
    width: 3.5rem;
    height: 3.5rem;

    border-radius: 50%;
    overflow: hidden;
    flex: 0 0 auto;
  }

  .site-icon {
    /* what: 枠の中で画像を大きめに表示して、見せたい位置に寄せる */
    /* how: object-fit: cover で枠いっぱいに敷き、transform で拡大と位置調整を同時に行う */
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.80) translateX(-2%) translateY(+18%);
    transform-origin: center;
  }

  .username {
    font-family: "Trebuchet MS", "Avenir Next", Avenir, "Helvetica Neue", sans-serif;
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    line-height: 1;
    text-transform: lowercase;
    color: var(--muted-text-color);
  }

  .site-center {
    /* what: タイトルと副題を中央にまとめる箱 */
    justify-self: center;

    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .site-title {
    /* what: 英語タイトルと日本語副題を縦に積む */
    /* how: flex-direction: column で並ぶ向きを縦に変える */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    color: var(--site-title-color);
    text-decoration: none;
  }

  .site-title-main {
    font-family: "Moon Dance", "Hiragino Sans", "Yu Gothic", YuGothic, cursive;
    font-size: 1.82rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.2;
  }

  .site-title-sub {
    font-family: "Zen Kurenaido", "Hiragino Sans", "Yu Gothic", YuGothic, sans-serif;
    font-size: 0.92rem;
    font-weight: 400;
    letter-spacing: 0.03em;
    line-height: 1.1;
    color: var(--muted-text-color);
  }

  .theme-toggle {
    /* what: トグルボタン自体の外枠を消して、中の見た目だけを使う */
    justify-self: end;

    height: 2.5rem;
    padding: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .menu-toggle {
    /* what: モバイルだけで表示するメニューボタン */
    /* how: ふだんは display: none で隠し、media query の中で表示する */
    display: none;
    justify-self: end;
    width: 2.75rem;
    height: 2.5rem;
    padding: 0;
    border: 1px solid var(--header-border);
    border-radius: 10px;
    background-color: var(--surface-background);
    color: var(--text-color);
    cursor: pointer;
  }

  .menu-toggle-lines {
    display: inline-flex;
    flex-direction: column;
    gap: 0.28rem;
  }

  .menu-toggle-lines span {
    display: block;
    width: 1.1rem;
    height: 2px;
    border-radius: 999px;
    background-color: currentColor;
  }

  .toggle-track {
    /* トグル全体のサイズをここに集めておくと、横幅やつまみ位置をまとめて調整しやすい */
    --track-width: 4.6rem;
    --track-height: 2.3rem;
    --track-padding: 0.24rem;
    --thumb-size: calc(var(--track-height) - (var(--track-padding) * 2));
    --thumb-translate: calc(var(--track-width) - var(--thumb-size) - (var(--track-padding) * 2) + 0.5rem);

    position: relative;
    /* what: トグル内の月・太陽・つまみを重ねて配置する土台 */
    /* how: position: relative を親に置くと、子の absolute はこの箱を基準に動く */
    display: block;
    width: var(--track-width);
    height: var(--track-height);
    padding: var(--track-padding);

    border-radius: 999px;
    background-color: var(--toggle-background);
  }

  .toggle-icon {
    /* what: 太陽と月のアイコンをトグルの左右に固定する */
    /* how: position: absolute で親要素の中の好きな場所へ置く */
    position: absolute;
    top: 50%;
    width: 1.65rem;
    height: 1.65rem;

    color: var(--toggle-icon);
    opacity: 0.88;
    transform: translateY(-50%);
  }

  .toggle-icon svg {
    display: block;
    width: 100%;
    height: 100%;

    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.9;
  }

  .toggle-icon-sun {
    left: 0.52rem;
  }

  .toggle-icon-moon {
    right: 0.52rem;
  }

  .toggle-thumb {
    position: absolute;
		/* 見た目の中心に合うように、少しだけ下へ補正している */
    top: calc(var(--track-padding) + 0.25rem);
    left: var(--track-padding);
    width: var(--thumb-size);
    height: var(--thumb-size);

    border-radius: 50%;
    background-color: var(--toggle-thumb);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.16);
    transition: transform 150ms ease;
  }

  .theme-toggle[data-state="dark"] .toggle-thumb {
    transform: translateX(var(--thumb-translate));
  }

  .theme-toggle:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 0.25rem;
  }

  @media (max-width: 720px) {
    .header-inner {
      /* what: モバイルでは 2 行レイアウトに組み替える */
      /* how: grid-template-areas で「1行目は title、2行目は owner / menu / toggle」と名前付きで並べる */
      grid-template-columns: minmax(0, 1fr) auto auto;
      grid-template-areas:
        "center center center"
        "owner menu toggle";
      row-gap: 0.9rem;

      min-height: auto;
      padding: 1rem 1rem 0.9rem;
    }

    .header-nav-row {
      /* モバイルでは横幅が狭いので、左右の余白を少し詰める */
      padding: 0 1rem 1rem;
    }

    .header-nav-row[hidden] {
      /* hidden 属性が付いたときだけ、開閉対象の nav 行を消す */
      display: none;
    }

    .site-owner {
      grid-area: owner;
      gap: 0.65rem;
    }

    .site-center {
      grid-area: center;
      justify-self: center;
      width: 100%;
    }

    .theme-toggle {
      grid-area: toggle;
      align-self: end;
    }

    .menu-toggle {
      display: inline-flex;
      grid-area: menu;
      justify-content: center;
      align-items: center;
      align-self: end;
    }

    .site-icon-frame {
      width: 2.8rem;
      height: 2.8rem;
    }

    .username {
      font-size: 1rem;
    }

    .site-title {
      gap: 0.1rem;
    }

    .site-title-main {
      font-size: 1.5rem;
      line-height: 1.15;
      text-align: center;
    }

    .site-title-sub {
      font-size: 0.84rem;
      text-align: center;
    }

    .toggle-track {
      /* モバイルではトグル全体を少しだけ小さくする */
      --track-width: 4rem;
      --track-height: 2rem;
      --track-padding: 0.22rem;
      --thumb-size: calc(var(--track-height) - (var(--track-padding) * 2));
      --thumb-translate: calc(var(--track-width) - var(--thumb-size) - (var(--track-padding) * 2) + 0.08rem);
    }

    .toggle-icon {
      width: 1.35rem;
      height: 1.35rem;
    }

    .toggle-thumb {
      top: calc(var(--track-padding) + 0.16rem);
    }
  }
</style>
