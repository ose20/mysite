---
import type { AboutEducationEntry } from "../../data/about";

interface Props {
	entries: AboutEducationEntry[];
}

const { entries } = Astro.props;
---

<section class="about-section" aria-labelledby="about-education-title">
	<div class="about-section-head">
		<p class="about-section-kicker">Background</p>
	</div>

	<div class="about-education-list">
		{
			entries.map((entry) => (
				<section class="about-education-entry">
					<h3 class="about-education-school">{entry.school}</h3>
					<ul class="about-education-details">
						{entry.details.map((detail) => <li>{detail}</li>)}
					</ul>
				</section>
			))
		}
	</div>
</section>

<style>
	.about-section {
		padding: 1.5rem;
		border: 1px solid var(--header-border);
		border-radius: 18px;
		background-color: var(--surface-background);
	}

	.about-section-head {
		margin-bottom: 1.15rem;
	}

	.about-section-kicker,
	.about-section-title {
		margin: 0;
	}

	.about-section-kicker {
		color: var(--muted-text-color);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.about-section-title {
		margin-top: 0.4rem;
		color: var(--post-title-color);
		font-size: 1.35rem;
		line-height: 1.3;
	}

	.about-education-list {
		display: grid;
		gap: 1rem;
	}

	.about-education-entry {
		padding: 1rem;
		border: 1px solid var(--header-border);
		border-radius: 14px;
		background-color: var(--header-background);
	}

	.about-education-school {
		margin: 0;
		color: var(--text-color);
		font-size: 1.02rem;
		line-height: 1.5;
	}

	.about-education-details {
		margin: 0.7rem 0 0;
		padding-left: 1.25rem;
		color: var(--muted-text-color);
		line-height: 1.8;
	}

	.about-education-details li + li {
		margin-top: 0.45rem;
	}

	@media (max-width: 720px) {
		.about-section {
			padding: 1.2rem;
		}

		.about-section-title {
			font-size: 1.2rem;
		}
	}
</style>
