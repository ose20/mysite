---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<section class="home-section">
	<h2 class="home-section-title">{title}</h2>
	<div class="home-section-body">
		<slot />
	</div>
</section>

<style>
	.home-section {
		/* what: 各セクションを上下の余白と区切り線で分ける */
		padding: 2rem 0;
		border-top: 1px solid var(--header-border);
	}

	.home-section:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.home-section-title {
		margin: 0 0 1rem;
		color: var(--post-title-color);
		font-family: "Hiragino Sans", "Yu Gothic", YuGothic, "Trebuchet MS", "Noto Sans CJK JP", sans-serif;
		font-size: 1.4rem;
		font-weight: 600;
		letter-spacing: 0.01em;
		line-height: 1.3;
	}

	.home-section-body {
		/* line-height は行と行の間隔。文章を読みやすくするために少し広めに取っている */
		color: var(--muted-text-color);
		font-size: 1rem;
		line-height: 1.9;
	}

	.home-section-body :global(p) {
		margin: 0;
	}

	.home-section-body :global(p + p) {
		margin-top: 0.95rem;
	}

	@media (max-width: 720px) {
		.home-section {
			padding: 1.6rem 0;
		}

		.home-section-title {
			margin-bottom: 0.85rem;
			font-size: 1.2rem;
		}
	}
</style>
