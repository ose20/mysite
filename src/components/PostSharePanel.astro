---
import CopyIcon from "./icons/CopyIcon.astro";
import RssIcon from "./icons/RssIcon.astro";
import XIcon from "./icons/XIcon.astro";

interface Props {
	title: string;
	url: string;
}

const { title, url } = Astro.props;
const shareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
---

<section class="share-panel" aria-label="共有リンク">
	<div class="share-actions">
		<a
			class="share-link"
			href={shareUrl}
			target="_blank"
			rel="noreferrer"
			aria-label="Xで共有"
			title="Xで共有"
		>
			<span class="share-icon" aria-hidden="true">
				<XIcon />
			</span>
		</a>
		<button
			class="share-link share-button"
			type="button"
			data-copy-link={url}
			aria-label="共有リンクをコピー"
			title="共有リンクをコピー"
		>
			<span class="share-icon" aria-hidden="true">
				<CopyIcon />
			</span>
		</button>
		<a class="share-link" href="/rss.xml" aria-label="RSS" title="RSS">
			<span class="share-icon" aria-hidden="true">
				<RssIcon />
			</span>
		</a>
	</div>
</section>

<script is:inline>
	const copyButtons = Array.from(document.querySelectorAll("[data-copy-link]"));

	for (const button of copyButtons) {
		button.addEventListener("click", async () => {
			const url = button.getAttribute("data-copy-link");
			if (!url) return;

			try {
				await navigator.clipboard.writeText(url);
				button.setAttribute("aria-label", "コピーしました");
				button.setAttribute("title", "コピーしました");
				window.setTimeout(() => {
					button.setAttribute("aria-label", "共有リンクをコピー");
					button.setAttribute("title", "共有リンクをコピー");
				}, 1600);
			} catch {
				button.setAttribute("aria-label", "コピーできませんでした");
				button.setAttribute("title", "コピーできませんでした");
				window.setTimeout(() => {
					button.setAttribute("aria-label", "共有リンクをコピー");
					button.setAttribute("title", "共有リンクをコピー");
				}, 1600);
			}
		});
	}
</script>

<style>
	.share-panel {
		/* what: 共有ボタン群だけを置く薄いコンテナ */
		/* how: 外枠カードは付けず、内側余白だけを少し持たせてボタン同士が詰まりすぎないようにする */
		padding: 0;
	}

	.share-actions {
		/* what: 共有アイコン 3 つを等幅で並べる */
		/* how: repeat(3, minmax(0, 1fr)) は「3 列を同じ幅で作る」という意味 */
		/* --share-icon-size を変えると、3 つのアイコンサイズをまとめて調整できる */
		--share-icon-size: 1.05rem;

		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.65rem;
	}

	.share-link {
		/* what: リンクと button を同じ見た目でそろえる */
		/* how: inline-flex を使うと、中の SVG を縦横の中央に置きやすい */
		display: inline-flex;
		justify-content: center;
		align-items: center;
		padding: 0.72rem;
		border: 1px solid var(--header-border);
		border-radius: 10px;
		background-color: var(--header-background);
		color: var(--text-color);
		text-decoration: none;
		cursor: pointer;
		transition: border-color 150ms ease, background-color 150ms ease, color 150ms ease;
	}

	.share-icon {
		/* what: 共有アイコンの共通サイズ */
		/* how: width / height を CSS 変数にまとめて、3 種類を一括で調整できるようにする */
		display: inline-flex;
		width: var(--share-icon-size);
		height: var(--share-icon-size);
	}

	.share-icon svg {
		display: block;
		width: 100%;
		height: 100%;
	}

	.share-link:hover,
	.share-link:focus-visible {
		border-color: var(--nav-active-border);
		background-color: var(--nav-active-background);
		color: var(--nav-active-text);
		outline: none;
	}

	.share-button {
		font: inherit;
	}
</style>
