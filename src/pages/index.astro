---
import { getCollection } from "astro:content";
import BaseHead from "../components/site/BaseHead.astro";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import HomeSection from "../components/home/HomeSection.astro";
import RecentPostsGrid from "../components/blog/RecentPostsGrid.astro";

const recentPosts = (await getCollection("blog"))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title="Home" description="ose20の個人サイト" />
	</head>
	<body>
		<Header />
		<main class="home-page">
			<HomeSection title="このブログについて">
				<p>
					ここは、技術や趣味、プライベートから仕事や社会まで幅広く自分の考えをまとめる場所です。
				</p>
			</HomeSection>

			<HomeSection title="Light for the Afflicted">
				<p>
					このブログのタイトルは、自分が日々を生きるうえで大事にしたいことが表現されていて、愛着が持てる文脈を持つものにしたかった。
				</p>
				<p>
					『アークナイツ』というゲームにアンドアインという求道者が登場する。私は彼の生きざまが大好きなのだが、副題の「苦難に光を」は、ゲーム中で彼が使うスキルの名前から拝借している。
				</p>
				<p>すべての命が尊重され、すべての苦難に手が差し伸べられる社会が一番強くてかっこいいと思います。「苦難に光を」、やっていきたい。</p>
			</HomeSection>

			<RecentPostsGrid posts={recentPosts} />
		</main>
		<Footer />
	</body>
</html>

<style>
	.home-page {
		/* what: ホーム全体の本文幅を整える箱 */
		/* how: max-width で読みやすい横幅に制限し、margin: 0 auto で中央に置く */
		max-width: 74rem;
		margin: 0 auto;
		padding: 3rem 1.25rem 4rem;
	}

	.home-inline-gallery {
		/* what: 画像 2 枚を横並びにする */
		/* how: grid の repeat(2, ...) は「同じ幅の列を 2 本作る」という意味 */
		display: grid;
		/* minmax(0, 1fr) は「最小 0、余った幅を均等に分ける列」を作る書き方 */
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		margin-top: 1.35rem;
	}

	.home-inline-image {
		/* what: 画像を親幅に合わせて縮め、縦横比は元画像のまま保つ */
		width: 100%;
		height: auto;
		border: 1px solid var(--header-border);
		border-radius: 12px;
		background-color: var(--surface-background);
		display: block;
	}

	.home-inline-credit {
		margin: 0.75rem 0 0;
		color: var(--muted-text-color);
		font-size: 0.82rem;
		letter-spacing: 0.02em;
	}

	@media (max-width: 720px) {
		.home-page {
			/* モバイルでは左右余白を少し詰めて、画面に対して本文を広めに使う */
			padding: 2rem 1rem 3rem;
		}
	}
</style>
