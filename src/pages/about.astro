---
import BaseHead from "../components/site/BaseHead.astro";
import AboutAccounts from "../components/about/AboutAccounts.astro";
import AboutCategoryCard from "../components/about/AboutCategoryCard.astro";
import AboutEducationSection from "../components/about/AboutEducationSection.astro";
import AboutHero from "../components/about/AboutHero.astro";
import AboutMiscSection from "../components/about/AboutMiscSection.astro";
import Footer from "../components/site/Footer.astro";
import Header from "../components/site/Header.astro";
import { aboutAccounts, aboutCategories, aboutEducation, aboutHero, aboutMisc } from "../data/about";
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead
			title="私について"
			description="ose20 の興味、背景、学んできたことをまとめたプロフィールページ"
		/>
	</head>
	<body>
		<Header />
		<main class="about-page">
			<AboutHero username={aboutHero.username} biography={aboutHero.biography} />
			<AboutAccounts accounts={aboutAccounts} />

			<section class="about-section-block" aria-labelledby="about-interests-title">
				<div class="about-section-head">
					<p class="about-section-kicker">Interests</p>
				</div>

				<div class="about-category-grid">
					{aboutCategories.map((category) => <AboutCategoryCard category={category} />)}
				</div>
			</section>

			<AboutEducationSection entries={aboutEducation} />
			<AboutMiscSection items={aboutMisc} />
		</main>
		<Footer />
	</body>
</html>

<style>
	.about-page {
		max-width: 76rem;
		margin: 0 auto;
		padding: 2.75rem 1.25rem 4rem;
		display: grid;
		gap: 1.4rem;
	}

	.about-section-block {
		padding: 1.5rem;
		border: 1px solid var(--header-border);
		border-radius: 18px;
		background-color: var(--surface-background);
	}

	.about-section-head {
		margin-bottom: 1.15rem;
	}

	.about-section-kicker,
	.about-section-title,
	.about-section-description {
		margin: 0;
	}

	.about-section-kicker {
		color: var(--muted-text-color);
		font-size: 0.82rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.about-section-title {
		margin-top: 0.4rem;
		color: var(--post-title-color);
		font-size: 1.35rem;
		line-height: 1.3;
	}

	.about-section-description {
		margin-top: 0.65rem;
		color: var(--muted-text-color);
		line-height: 1.8;
	}

		.about-category-grid {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			align-items: start;
			gap: 1rem;
		}

	@media (max-width: 720px) {
		.about-page {
			padding: 2rem 1rem 3rem;
		}

		.about-section-block {
			padding: 1.2rem;
		}

		.about-section-title {
			font-size: 1.2rem;
		}

		.about-category-grid {
			grid-template-columns: minmax(0, 1fr);
		}
	}
</style>
